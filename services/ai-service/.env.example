# ====== 医小管 AI 服务环境变量 ======
# 复制此文件为 .env 并填入真实值

# DashScope（阿里云大模型）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_KB=kb_entries
CHROMA_COLLECTION_LINKS=quick_links

# business-api 回调地址
BUSINESS_API_BASE_URL=http://localhost:8080

# 调试模式
DEBUG=true
